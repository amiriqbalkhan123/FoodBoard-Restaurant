<section class="mb-12">
  <div class="luxury-dark text-white rounded-[42px] p-10 premium-shadow persian-frame">

    <p class="text-amber-300 font-black uppercase tracking-[0.3em] text-sm">
      External API Integration
    </p>

    <h1 class="brand-font text-6xl font-black mt-4">
      Global Food Explorer
    </h1>

    <p class="text-orange-100 mt-5 text-lg">
      Search meals from a public food API with Afghan food fallback highlights.
    </p>

    <div class="mt-5">
      <span class="badge badge-gold">
        API Status: <%= apiStatus %>
      </span>
    </div>

    <form method="GET" action="/external-foods" class="grid grid-cols-1 md:grid-cols-4 gap-4 mt-8">

      <input
        type="text"
        name="search"
        value="<%= search %>"
        placeholder="Search chicken, rice, lamb, pasta..."
        class="input-luxury md:col-span-2"
      />

      <button class="btn-luxury">
        Search
      </button>

      <a href="/external-foods/random" class="btn-luxury">
        Random Meal
      </a>

    </form>

  </div>
</section>

<section class="mb-14">

  <h2 class="brand-font text-4xl font-black mb-6">
    Afghan Food Highlights
  </h2>

  <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-8">

    <% afghanFoods.forEach(food => { %>

      <div class="glass-card premium-shadow rounded-[34px] overflow-hidden card-hover">

        <img
          src="<%= food.strMealThumb %>"
          class="w-full h-56 object-cover skeleton"
        />

        <div class="p-6">

          <span class="badge badge-gold">
            <%= food.strArea %>
          </span>

          <h3 class="brand-font text-3xl font-black mt-4">
            <%= food.strMeal %>
          </h3>

          <p class="text-gray-600 mt-3 leading-relaxed">
            <%= food.strInstructions %>
          </p>

        </div>

      </div>

    <% }) %>

  </div>

</section>

<section>

  <h2 class="brand-font text-4xl font-black mb-6">
    API Results
  </h2>

  <% if(meals.length === 0) { %>

    <div class="glass-card premium-shadow rounded-[36px] p-14 text-center">
      <h3 class="brand-font text-5xl font-black">
        No API Meals Found
      </h3>

      <p class="text-gray-500 mt-4">
        Try searching chicken, beef, rice, lamb, pasta or dessert.
      </p>
    </div>

  <% } else { %>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">

      <% meals.forEach(meal => { %>

        <div class="glass-card premium-shadow rounded-[34px] overflow-hidden card-hover">

          <img
            src="<%= meal.strMealThumb %>"
            class="w-full h-60 object-cover skeleton"
          />

          <div class="p-7">

            <div class="flex flex-wrap gap-2">

              <span class="badge badge-gold">
                <%= meal.strCategory || 'Meal' %>
              </span>

              <span class="badge bg-white text-gray-700">
                <%= meal.strArea || 'Global' %>
              </span>

            </div>

            <h3 class="brand-font text-3xl font-black mt-5">
              <%= meal.strMeal %>
            </h3>

            <p class="text-gray-600 mt-3 leading-relaxed">
              <%= meal.strInstructions
                ? meal.strInstructions.substring(0, 150) + '...'
                : 'No instructions available.'
              %>
            </p>

            <% if(meal.strYoutube) { %>
              <a
                href="<%= meal.strYoutube %>"
                target="_blank"
                class="inline-block mt-6 btn-luxury"
              >
                Watch Recipe
              </a>
            <% } %>

          </div>

        </div>

      <% }) %>

    </div>

  <% } %>

</section>