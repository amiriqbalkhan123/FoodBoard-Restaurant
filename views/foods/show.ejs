<div class="max-w-4xl mx-auto bg-white rounded-2xl shadow-lg overflow-hidden">

  <img
    src="<%= food.imageUrl || 'https://images.unsplash.com/photo-1546069901-ba9599a7e63c' %>"
    class="w-full h-96 object-cover"
  />

  <div class="p-8">

    <div class="flex justify-between items-center">

      <h1 class="text-4xl font-bold text-gray-800">
        <%= food.name %>
      </h1>

      <span
        class="bg-orange-100 text-orange-600 px-4 py-2 rounded-full"
      >
        <%= food.category %>
      </span>

    </div>

    <p class="text-gray-600 mt-6 text-lg">
      <%= food.description %>
    </p>

    <div class="mt-8 flex justify-between items-center">

      <span class="text-4xl font-bold text-orange-500">
        AFN <%= food.price %>
      </span>

      <% if(food.availability) { %>

        <span
          class="bg-green-100 text-green-600 px-4 py-2 rounded-full"
        >
          Available
        </span>

      <% } else { %>

        <span
          class="bg-red-100 text-red-600 px-4 py-2 rounded-full"
        >
          Not Available
        </span>

      <% } %>

    </div>

    <% if(user) { %>

      <div class="flex gap-4 mt-8">

        <a
          href="/foods/edit/<%= food._id %>"
          class="bg-blue-500 hover:bg-blue-600 text-white px-6 py-3 rounded-lg"
        >
          Edit
        </a>

        <form
          action="/foods/<%= food._id %>?_method=DELETE"
          method="POST"
        >

          <button
            class="bg-red-500 hover:bg-red-600 text-white px-6 py-3 rounded-lg"
          >
            Delete
          </button>

        </form>

      </div>

    <% } %>

  </div>

</div>