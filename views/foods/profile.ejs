<section class="max-w-6xl mx-auto">

  <div class="luxury-dark text-white rounded-[42px] p-10 md:p-12 premium-shadow persian-frame">

    <p class="text-amber-300 font-black uppercase tracking-[0.3em] text-sm">
      Restaurant Identity
    </p>

    <h1 class="brand-font text-6xl font-black mt-4">
      FoodBoard Palace
    </h1>

    <p class="text-orange-100 mt-5 text-lg max-w-3xl">
      A premium Afghan and Persian-inspired restaurant dashboard for managing signature dishes,
      menu visibility, customer favorites, ratings, and digital dining experiences.
    </p>

  </div>

  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mt-10">

    <div class="glass-card premium-shadow rounded-[30px] p-7">
      <p class="text-gray-500 font-bold">Total Dishes</p>
      <h2 class="text-4xl font-black mt-2"><%= totalFoods %></h2>
    </div>

    <div class="glass-card premium-shadow rounded-[30px] p-7">
      <p class="text-gray-500 font-bold">Available</p>
      <h2 class="text-4xl font-black mt-2 text-green-600"><%= availableFoods %></h2>
    </div>

    <div class="glass-card premium-shadow rounded-[30px] p-7">
      <p class="text-gray-500 font-bold">Featured</p>
      <h2 class="text-4xl font-black mt-2 text-orange-600"><%= featuredFoods %></h2>
    </div>

    <div class="glass-card premium-shadow rounded-[30px] p-7">
      <p class="text-gray-500 font-bold">Trending</p>
      <h2 class="text-4xl font-black mt-2 text-amber-600"><%= trendingFoods %></h2>
    </div>

  </div>

  <div class="glass-card premium-shadow rounded-[36px] p-8 mt-10">

    <h2 class="brand-font text-4xl font-black mb-6">
      Menu Categories
    </h2>

    <% if(categories.length === 0) { %>

      <p class="text-gray-500 font-bold">
        No categories available yet.
      </p>

    <% } else { %>

      <div class="flex flex-wrap gap-3">

        <% categories.forEach(category => { %>

          <span class="badge badge-gold">
            <%= category %>
          </span>

        <% }) %>

      </div>

    <% } %>

  </div>

</section>