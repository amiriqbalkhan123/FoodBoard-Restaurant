<div class="max-w-5xl mx-auto glass-card premium-shadow p-8 md:p-10 rounded-[38px]">

  <p class="text-orange-600 font-black uppercase tracking-[0.25em] text-sm">
    Menu Update
  </p>

  <h1 class="brand-font text-5xl font-black mt-3">
    Edit Dish
  </h1>

  <p class="text-gray-500 mt-3 mb-8">
    Update dish information, visibility, status and premium menu flags.
  </p>

  <form action="/foods/<%= food._id %>?_method=PUT" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-6">

    <div>
      <label class="block mb-2 font-black">Dish Name</label>
      <input type="text" name="name" value="<%= food.name %>" required class="input-luxury" />
    </div>

    <div>
      <label class="block mb-2 font-black">Category</label>
      <input type="text" name="category" value="<%= food.category %>" required class="input-luxury" />
    </div>

    <div>
      <label class="block mb-2 font-black">Price AFN</label>
      <input type="number" name="price" value="<%= food.price %>" min="0" required class="input-luxury" />
    </div>

    <div>
      <label class="block mb-2 font-black">Cuisine</label>
      <input type="text" name="cuisine" value="<%= food.cuisine %>" class="input-luxury" />
    </div>

    <div>
      <label class="block mb-2 font-black">Preparation Time</label>
      <input type="number" name="prepTime" value="<%= food.prepTime %>" min="1" class="input-luxury" />
    </div>

    <div>
      <label class="block mb-2 font-black">Calories</label>
      <input type="number" name="calories" value="<%= food.calories %>" min="0" class="input-luxury" />
    </div>

    <div>
      <label class="block mb-2 font-black">Spice Level</label>
      <select name="spiceLevel" class="input-luxury">
        <option value="Mild" <%= food.spiceLevel === 'Mild' ? 'selected' : '' %>>Mild</option>
        <option value="Medium" <%= food.spiceLevel === 'Medium' ? 'selected' : '' %>>Medium</option>
        <option value="Spicy" <%= food.spiceLevel === 'Spicy' ? 'selected' : '' %>>Spicy</option>
        <option value="Very Spicy" <%= food.spiceLevel === 'Very Spicy' ? 'selected' : '' %>>Very Spicy</option>
      </select>
    </div>

    <div>
      <label class="block mb-2 font-black">Image URL</label>
      <input type="text" name="imageUrl" value="<%= food.imageUrl %>" class="input-luxury" />
    </div>

    <div class="md:col-span-2">
      <label class="block mb-2 font-black">Description</label>
      <textarea name="description" rows="5" required class="input-luxury"><%= food.description %></textarea>
    </div>

    <div class="md:col-span-2 grid grid-cols-1 md:grid-cols-3 gap-4">

      <label class="glass-card rounded-2xl p-4 font-black flex items-center gap-3">
        <input type="checkbox" name="availability" <%= food.availability ? 'checked' : '' %> />
        Available
      </label>

      <label class="glass-card rounded-2xl p-4 font-black flex items-center gap-3">
        <input type="checkbox" name="isFeatured" <%= food.isFeatured ? 'checked' : '' %> />
        Featured Dish
      </label>

      <label class="glass-card rounded-2xl p-4 font-black flex items-center gap-3">
        <input type="checkbox" name="isTrending" <%= food.isTrending ? 'checked' : '' %> />
        Trending Dish
      </label>

    </div>

    <button class="btn-luxury md:col-span-2">
      Update Dish
    </button>

  </form>

</div>