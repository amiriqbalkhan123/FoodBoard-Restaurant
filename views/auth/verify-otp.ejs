<div class="min-h-[75vh] flex items-center justify-center">

  <div class="max-w-md w-full glass-card premium-shadow p-10 rounded-[32px]">

    <h1 class="text-4xl font-extrabold text-center mb-3 text-gray-900">
      Verify Email
    </h1>

    <p class="text-center text-gray-500 mb-8">
      Enter the 6-digit OTP code sent to your email.
    </p>

    <form action="/verify-otp" method="POST">

      <div class="mb-6">
        <label class="block mb-2 font-bold text-gray-700">
          OTP Code
        </label>

        <input
          type="text"
          name="otpCode"
          maxlength="6"
          required
          class="input-luxury text-center text-2xl tracking-[0.4em] font-extrabold"
        />
      </div>

      <button class="btn-luxury w-full">
        Verify Account
      </button>

    </form>

    <form action="/resend-otp" method="POST" class="mt-5 text-center">
      <button class="text-orange-600 font-bold hover:text-orange-700">
        Resend OTP
      </button>
    </form>

  </div>

</div>